# Finding the max number within a list

# Define function
def find_max(numbers):
    if not numbers or len(numbers) == 0:
        print("List is empty.")
        return None
    # Return the max number
    return max(numbers)

# List of numbers
nums = [2, 20, 50, 30, 2, 1]

# Display output
print(f'The maximum number in the list is: {find_max(nums)}')


# Finding a desired number within the Fibonacci sequence?
def fibonacciSequence(desired_value):
    # Initial values
    num_a = 0
    num_b = 1
    next_num = 0

    if desired_value == 0 or desired_value == 1:
        return f'Number: {desired_value} has been reached!'

    # While loop iterating until the desired result
    while True:
        next_num = num_a + num_b # Set next number equal to the sum of a and b
        num_a = num_b # Set initial value equal to next value
        num_b = next_num # Set next value equal to the sum
        print(f'Current Num: {num_b}') # Displaying current num

        # The condition where the loop iterates. When the desired value is reached, return that the number has been found
        if num_b == desired_value:
            return f'Number: {num_b} has been reached!'
        # If the desired value is not within the Fibonacci Sequence, return that the number is not in the sequence
        if num_b > desired_value:
            return f'Number: {desired_value} is not in the Fibonacci Sequence.'


# Nested loops to process numbers in row and column format
def grid(rows, cols):
    value = 1
    for i in range(rows):
        for j in range(cols):
            print(value, end="\t")
            value += 1
        print()


# Input your number here!
user_num = int(input("Enter a number within the Fibonacci Sequence here: "))

# Call function
print(fibonacciSequence(user_num))

# Number 89 is in the Fibonacci Sequence so the while loop iterates until 89 is reached
print(fibonacciSequence(89))

# However, 30 is not in the Fibonacci Sequence. Therefore it will iterate to the next Fibonacci Sequence greater than desired number
print(fibonacciSequence(30))

# Grid example
rows = int(input("Enter number of rows: "))
cols = int(input("Enter number of columns: "))
print("Grid output:")
grid(rows, cols)
